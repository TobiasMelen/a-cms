---
//@ts-expect-error Something is going on with astro imports
import { ClientRouter } from "astro:transitions";
import { API_PREFIX } from "../constants";
import { Page } from "../data/repository";
import { buildTree } from "../resolve";
import PageTree from "./PageTree";
import FieldEdit from "./FieldEdit.astro";

interface Props {
  page: Page;
}
const { items, urls } = buildTree();
const { page } = Astro.props;
---

<PageTree
  items={items}
  urls={urls}
  currentPageId={page.id}
  apiPrefix={API_PREFIX}
  client:load
  transition:persist
/>

<FieldEdit page={page} />

<ClientRouter />
